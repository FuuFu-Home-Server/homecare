{
  "name": "homecare",
  "version": "0.1.5",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"db/**/*.ts\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p electron/tsconfig.json",
    "db:reset": "ELECTRON_RUN_AS_NODE=1 electron node_modules/tsx/dist/cli.mjs db/reset.ts",
    "db:seed": "ELECTRON_RUN_AS_NODE=1 electron node_modules/tsx/dist/cli.mjs db/seed.ts",
    "test": "ELECTRON_RUN_AS_NODE=1 electron --import tsx --test src/lib/fefo.test.ts src/lib/db/migrations.test.ts src/lib/db/payroll.test.ts src/lib/db/visit-flow.test.ts",
    "gen:routes": "node scripts/gen-routes.mjs",
    "build:desktop": "node scripts/build-desktop.mjs",
    "electron:build": "npm run gen:routes && node scripts/build-electron.mjs",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3-multiple-ciphers",
    "electron:launch": "npm run electron:build && wait-on tcp:3000 && electron .",
    "electron:dev": "concurrently -k -n next,electron \"npm:dev\" \"npm:electron:launch\"",
    "electron:preview": "npm run build:desktop && npm run electron:build && HOMECARE_RENDERER=static electron .",
    "dist": "npm run build:desktop && npm run electron:build && electron-builder --win --publish never",
    "release": "npm run build:desktop && npm run electron:build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3-multiple-ciphers": "^12.10.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "iron-session": "^8.0.4",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-to-print": "^3.0.5",
    "recharts": "^2.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/eslintrc": "^3.2.0",
    "@faker-js/faker": "^9.4.0",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.0",
    "wait-on": "^8.0.1"
  }
}
